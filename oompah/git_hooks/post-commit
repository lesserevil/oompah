#!/usr/bin/env python3
"""post-commit — oompah Backlog.md task-change webhook notifier.

Fires after every git commit in a managed project repository. If the
commit includes changes to backlog task files (``backlog/tasks/*.md`` or
``backlog/completed/*.md``), POSTs a webhook notification to the
configured oompah server so it can promptly sync and refresh.

Configuration (stored in ``.git/config`` of the managed repo):

    oompah.backlog-webhook-url    Full endpoint URL. Defaults to
                                  http://localhost:8080/api/v1/webhooks/backlog
    oompah.backlog-webhook-secret HMAC-SHA256 shared secret.  When set
                                  the POST body is signed as
                                  ``X-Oompah-Signature: sha256=<hex>``.
    oompah.project-id             oompah project identifier.

This file is intentionally self-contained — it must not import any
oompah modules, since it runs in agent worktrees that may not have the
oompah package on ``sys.path``.

Best-effort: any failure is silently swallowed so git commits are never
blocked by a webhook delivery error (oompah may be down, the network
may be unreachable, etc.).
"""
from __future__ import annotations

import hashlib
import hmac
import json
import subprocess
import sys
import urllib.error
import urllib.request

_BACKLOG_PREFIXES = ("backlog/tasks/", "backlog/completed/")
_DEFAULT_WEBHOOK_URL = "http://localhost:8080/api/v1/webhooks/backlog"
_REQUEST_TIMEOUT_S = 3
# Sentinel written into the hook file so installation is idempotent.
# If the installed hook contains this marker, it is oompah-managed.
_OOMPAH_HOOK_MARKER = "# oompah-backlog-webhook-hook"


def _run_git(*args: str, timeout: int = 5) -> str:
    """Run a git sub-command; return stdout stripped, or '' on failure."""
    try:
        result = subprocess.run(
            ["git", *args],
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        if result.returncode == 0:
            return result.stdout.strip()
    except Exception:
        pass
    return ""


def _get_changed_backlog_files() -> list[str]:
    """Return paths of backlog task files modified in HEAD."""
    output = _run_git("diff-tree", "--no-commit-id", "-r", "--name-only", "HEAD")
    if not output:
        return []
    return [
        f
        for f in output.splitlines()
        if any(f.startswith(p) for p in _BACKLOG_PREFIXES)
        and f.endswith(".md")
    ]


def _git_config(key: str) -> str:
    """Read a local git config value; return '' if not set."""
    return _run_git("config", "--local", key)


def main() -> int:
    changed = _get_changed_backlog_files()
    if not changed:
        return 0

    url = _git_config("oompah.backlog-webhook-url") or _DEFAULT_WEBHOOK_URL
    project_id = _git_config("oompah.project-id") or ""
    secret = _git_config("oompah.backlog-webhook-secret") or ""

    payload = json.dumps(
        {
            "project_id": project_id,
            "event": "task_changed",
            "files": changed,
        }
    ).encode("utf-8")

    headers: dict[str, str] = {"Content-Type": "application/json"}
    if secret:
        mac = hmac.new(secret.encode("utf-8"), payload, hashlib.sha256)
        headers["X-Oompah-Signature"] = f"sha256={mac.hexdigest()}"

    try:
        req = urllib.request.Request(
            url,
            data=payload,
            headers=headers,
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=_REQUEST_TIMEOUT_S):
            pass
    except Exception:
        # Best-effort: never block a commit due to webhook failures.
        pass

    return 0


if __name__ == "__main__":
    sys.exit(main())
