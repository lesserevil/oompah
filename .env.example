# oompah environment configuration
#
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically on startup, or you can specify a
# different path with: oompah --env-file /path/to/your.env
#
# Values in this file take precedence over inherited shell environment
# variables when oompah starts.

# ---------------------------------------------------------------------------
# Webhook forwarding
# ---------------------------------------------------------------------------

# URL passed to 'gh webhook forward --url' for each project's gh CLI invocation.
# Each project runs its own gh webhook forward process in its repo_path.
# Defaults to http://localhost:8080/api/v1/webhooks/github if not set.
OOMPAH_WEBHOOK_FORWARD_URL=http://localhost:8080/api/v1/webhooks/github

# Comma-separated list of GitHub event types to subscribe to via
# 'gh webhook forward --events'. Must include all events oompah parses:
#   push, pull_request         — SCM events (source sync, PR lifecycle)
#   issues, issue_comment      — task changes for GitHub-backed task tracking
#   label                      — label create/edit/delete for routing hints
# Do not include projects_v2_item here: GitHub rejects that event for
# repository-scoped hooks created by 'gh webhook forward'. Oompah can parse
# projects_v2_item if an organization/user-level webhook delivers it separately.
# Removing an event from this list silences that event type even when
# oompah has parsing code for it.
# OOMPAH_WEBHOOK_EVENTS=push,pull_request,issues,issue_comment,label

# ---------------------------------------------------------------------------
# GitHub / GitLab authentication
# ---------------------------------------------------------------------------

# GitHub personal access token (used by the gh CLI for repository operations).
# When webhook forwarding is enabled, a fine-grained token MUST grant the
# target repository Webhooks: Read and write so `gh webhook forward` can
# create and manage its repository webhook. It also needs the permissions for
# the other oompah features you enable (for example, Contents and Pull
# requests). Alternatively, run `gh auth login` to authenticate interactively.
GITHUB_TOKEN=ghp_...

# GitHub Issues task hub used when WORKFLOW.md has tracker.kind=github_issues
# and a managed project does not provide its own tracker_owner/tracker_repo.
OOMPAH_GITHUB_TRACKER_OWNER=lesserevil
OOMPAH_GITHUB_TRACKER_REPO=oompah
# Optional GitHub Projects v2 board node ID for the task hub.
# OOMPAH_GITHUB_PROJECT_NODE_ID=

# Native Markdown tracker writes task files under .oompah/tasks and commits /
# pushes them from the managed source checkout by default. Disable only for
# tests or one-off local experiments.
# OOMPAH_MD_TRACKER_GIT_SYNC=1

# GitLab personal access token (used by the glab CLI for MR operations).
# Alternatively, run `glab auth login` to authenticate interactively.
GITLAB_TOKEN=glpat-...

# ---------------------------------------------------------------------------
# Workspace settings
# ---------------------------------------------------------------------------

# Root directory where agent workspaces / git worktrees are created.
# Defaults to a system temp directory if not set.
OOMPAH_WORKSPACE_ROOT=/tmp/oompah_workspaces

# ---------------------------------------------------------------------------
# Orchestrator tuning
# ---------------------------------------------------------------------------

# Maximum number of agents running in parallel (default: 10)
OOMPAH_MAX_CONCURRENT_AGENTS=5

# Spending cap in USD — dispatch stops when this is reached (0 = unlimited)
OOMPAH_BUDGET_LIMIT=50.00

# Rolling budget window: hour | day | week. The cap above resets at the
# next calendar boundary (top of hour / local midnight / Sunday 00:00).
# Default: day.
# OOMPAH_BUDGET_WINDOW=day

# IANA timezone name used to align budget rolls to calendar boundaries.
# Empty (default) auto-detects the host's local timezone via TZ env or
# /etc/localtime. Set explicitly when you want a specific zone, e.g.
# "America/Los_Angeles" or "UTC". Invalid names fall back to UTC with a
# warning.
# OOMPAH_BUDGET_TIMEZONE=

# HTTP dashboard port (defaults to 8080 when unset; leave blank to disable)
OOMPAH_SERVER_PORT=8080

# HTTP server backend: uvicorn (default) or granian.
# Granian is a Rust/Tokio ASGI server with ~23% higher HTTP throughput than
# uvicorn in single-worker benchmarks. It is opt-in behind --server granian
# until the integration is fully hardened (see TASK-472).
# Can also be set on the CLI: oompah --server granian
# OOMPAH_SERVER_BACKEND=uvicorn

# Number of server worker processes (default: 1).
# IMPORTANT: granian requires workers=1. oompah holds shared in-process state
# (the orchestrator singleton and the _ws_clients WebSocket set in
# oompah/server.py) that is not safe to share across multiple OS-level worker
# processes. Setting OOMPAH_SERVER_WORKERS > 1 with granian will be rejected
# at startup with a clear error message.
# Can also be set on the CLI: oompah --workers 1
# OOMPAH_SERVER_WORKERS=1

# Polling interval in milliseconds (default: 120000)
OOMPAH_POLL_INTERVAL_MS=120000

# Full safety-net sync interval in milliseconds (default: 300000)
# OOMPAH_FULL_SYNC_INTERVAL_MS=300000

# Maximum dispatch candidates to examine per tick (0 = no cap, default: 64)
# OOMPAH_DISPATCH_SCAN_LIMIT=64

# Extra dispatchable candidates to keep beyond currently-free agent slots
# before ending the selection pass (default: 8)
# OOMPAH_DISPATCH_READY_BUFFER=8

# Maximum candidates to run duplicate detection on per tick
# (0 = no cap, default: 64)
# OOMPAH_DUPLICATE_DETECTION_CANDIDATE_LIMIT=64

# Auto-archive and worktree cleanup budgets. These keep maintenance from
# monopolizing a scheduler tick after a large backlog has accumulated.
# OOMPAH_AUTO_ARCHIVE_BATCH_SIZE=25
# OOMPAH_AUTO_ARCHIVE_INTERVAL_SECONDS=300
# OOMPAH_WORKTREE_CLEANUP_BATCH_SIZE=25
# OOMPAH_MAINTENANCE_STARTUP_DELAY_SECONDS=60
# OOMPAH_RELEASE_PICK_MAX_RUNTIME_SECONDS=15
# OOMPAH_MERGED_LABELS_MAX_RUNTIME_SECONDS=15
# OOMPAH_ISSUES_SNAPSHOT_STALE_MS=60000

# ---------------------------------------------------------------------------
# Multi-process service split (TASK-469.5.1)
# ---------------------------------------------------------------------------
# SQLite database path shared between the scheduler and API processes.
# When set, the scheduler publishes state/issues snapshots to this database
# after every tick; the API process reads from it instead of blocking on the
# scheduler's Python GIL (YAML parsing).  Leave unset (default) for the
# standard single-process combined mode.
#
# Example (shared tmpfs for low-latency reads):
# OOMPAH_IPC_DB_PATH=/tmp/oompah_ipc.db
#
# See plans/service-split.md for the full architecture and roadmap.
# OOMPAH_IPC_DB_PATH=

# ---------------------------------------------------------------------------
# Agent behaviour
# ---------------------------------------------------------------------------

# Timeout for agent `run_command` shell tools (default: 720). Keep this above
# `OOMPAH_TASK_CLI_TIMEOUT_SECONDS` so a busy but successful local task update
# is not killed by the agent tool wrapper first.
# OOMPAH_AGENT_COMMAND_TIMEOUT_SECONDS=720

# Timeout for `oompah task ...` CLI calls to the local server (default: 600).
# Increase this if agents post comments or task updates while the server is
# busy enough that successful API calls approach the client timeout.
# OOMPAH_TASK_CLI_TIMEOUT_SECONDS=600

# Consecutive turns with no productive action before marking agent as stalled (default: 10)
OOMPAH_STALL_TURNS=10

# Escalate to a deeper profile after N failed attempts (default: 1)
OOMPAH_ESCALATE_AFTER_ATTEMPTS=1

# Start every issue on the catch-all "default" profile instead of the best match.
# Only escalate to the matched profile after a failed attempt. Saves budget when
# most issues resolve on the cheap default model. Default: false (opt-in).
# Also configurable via agent.default_first_dispatch: true in WORKFLOW.md.
OOMPAH_DEFAULT_FIRST_DISPATCH=false

# Completion verifier (oompah-zlz_2-y0ns). When true, after a worker exits
# successfully AND has moved the task to a terminal state, oompah runs a
# two-stage verifier against the task's "# Acceptance criteria" section:
#   - Stage 1: regex extract file/symbol references from AC, check they
#     appear in the agent's diff against the project's base branch.
#   - Stage 2 (only if stage 1 finds gaps): zero-shot LLM call to the
#     provider's "fast" model — asks YES/NO whether the diff fulfils
#     the AC.
# If verification rejects, the close is undone (task reopened) with a
# diagnostic comment, and a retry is scheduled (up to 3 times). Default
# false during initial rollout — flip to true after a soak window.
OOMPAH_VERIFY_COMPLETION=false

# Companion flag: when false, the LLM stage 2 of the verifier is skipped
# entirely (stage 1 still runs but only rejects on missing FILE
# references, not symbol misses — symbols need the LLM for nuance).
# Useful for offline / provider-less testing. Default: true.
OOMPAH_VERIFY_COMPLETION_LLM=true

# Source of truth for agent.profiles[]. By default the JSON store at
# .oompah/agent_profiles.json wins after a one-shot migration from
# WORKFLOW.md, so profiles are edited via the dashboard UI. Set this to
# "workflow" to keep WORKFLOW.md authoritative — the UI then becomes
# read-only. See docs/agent-profiles.md for the full precedence rules.
# OOMPAH_AGENT_PROFILES_SOURCE=workflow

# Source-of-truth strictness for agent.profiles configuration
# (oompah-zlz_2-hye). Agent profiles live in
# .oompah/agent_profiles.json (managed via /api/v1/agent-profiles); the
# legacy WORKFLOW.md agent.profiles block is no longer authoritative.
#  - "warn"   (default) — log a warning and surface a dashboard alert
#                         when WORKFLOW.md still has a stale block that
#                         differs from the persisted store. Continue.
#  - "strict"           — refuse to start if WORKFLOW.md still has any
#                         agent.profiles block at all. Use after the
#                         migration to lock the legacy section out.
# Also configurable via agent.strict_profile_source in WORKFLOW.md.
# OOMPAH_STRICT_PROFILE_SOURCE=warn

# Auto-decompose issue into sub-tasks after N failed attempts (default: 2)
OOMPAH_DECOMPOSE_AFTER_ATTEMPTS=2

# Max backoff delay between retries in milliseconds (default: 300000)
OOMPAH_MAX_RETRY_BACKOFF_MS=300000

# TTL (seconds) for the GitHubProvider per-PR DETAIL fetch cache
# (oompah/scm.py). The cache is keyed on (head_sha, updated_at), but
# GitHub does NOT always bump updated_at when async-recomputing
# mergeable_state after a base-branch commit lands — without a TTL,
# stale cached "clean" entries can persist indefinitely. Default 60s
# is a small per-PR refresh cost in exchange for catching DIRTY
# transitions that GitHub silently recomputes.
# OOMPAH_PR_DETAIL_CACHE_TTL_SECONDS=60

# ---------------------------------------------------------------------------
# Model providers
# ---------------------------------------------------------------------------
# Provider configuration (base URLs, API keys, models, roles) is managed
# in .oompah/providers.json — NOT in this file. Each provider has its own
# base_url and api_key, supporting multiple providers simultaneously.
#
# Use the dashboard or API to add/edit providers, or edit the file directly.
# See .oompah/providers.json for the current configuration.
