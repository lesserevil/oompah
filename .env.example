# oompah environment configuration
#
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically on startup, or you can specify a
# different path with: oompah --env-file /path/to/your.env
#
# Variables already set in the shell environment take precedence over
# values in this file (no-override mode by default).

# ---------------------------------------------------------------------------
# GitHub / GitLab authentication
# ---------------------------------------------------------------------------

# GitHub personal access token (used by the gh CLI for PR operations).
# Alternatively, run `gh auth login` to authenticate interactively.
GITHUB_TOKEN=ghp_...

# GitLab personal access token (used by the glab CLI for MR operations).
# Alternatively, run `glab auth login` to authenticate interactively.
GITLAB_TOKEN=glpat-...

# ---------------------------------------------------------------------------
# Workspace settings
# ---------------------------------------------------------------------------

# Root directory where agent workspaces / git worktrees are created.
# Defaults to a system temp directory if not set.
OOMPAH_WORKSPACE_ROOT=/tmp/oompah_workspaces

# ---------------------------------------------------------------------------
# Orchestrator tuning
# ---------------------------------------------------------------------------

# Maximum number of agents running in parallel (default: 10)
OOMPAH_MAX_CONCURRENT_AGENTS=5

# Spending cap in USD — dispatch stops when this is reached (0 = unlimited)
OOMPAH_BUDGET_LIMIT=50.00

# HTTP dashboard port (leave blank to disable the dashboard)
OOMPAH_SERVER_PORT=8080

# ---------------------------------------------------------------------------
# Model providers
# ---------------------------------------------------------------------------
# Provider configuration (base URLs, API keys, models, roles) is managed
# in .oompah/providers.json — NOT in this file. Each provider has its own
# base_url and api_key, supporting multiple providers simultaneously.
#
# Use the dashboard or API to add/edit providers, or edit the file directly.
# See .oompah/providers.json for the current configuration.
