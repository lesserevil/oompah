# Historical: merge driver for the old beads issue store (.beads/issues.jsonl).
# beads is no longer used — oompah now uses the native .oompah/tasks tracker.
# This attribute is retained so forks or branches that still have
# .beads/issues.jsonl get deterministic merge behaviour rather than conflicts.
# The driver is NOT installed automatically; _install_beads_merge_driver() was
# removed from oompah/projects.py when beads was retired.
.beads/issues.jsonl merge=beads-jsonl
