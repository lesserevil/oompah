
# Dolt database files (added by bd init)
.dolt/
*.db

# beads-jsonl-ignore (managed by oompah)
# Beads JSONL backups — dolt sync (refs/dolt/data) is the source of truth.
# Tracking these in git creates a redundant second copy that conflicts
# whenever two PRs touch beads simultaneously. See oompah-zlz_2-mp4v.
# The files themselves still exist locally (export.auto=true) for
# emergency recovery via `bd bootstrap`.
.beads/*.jsonl
.beads/backup/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
*.egg

# Oompah local config
.oompah/

# Per-project console transcripts (oompah-zlz_2-ebwe). Already covered
# by ``.oompah/`` above, but listed explicitly so the path is greppable
# for operators looking up where the console persists state.
.oompah/console/

# Environment variables — never commit secrets
.env

*.log
*.pid

# Beads / Dolt files (added by bd init)
.beads-credential-key
