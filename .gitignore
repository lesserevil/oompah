
# Historical: Dolt/beads files from the old task tracker (pre-.oompah/tasks).
# beads and bd are no longer used; oompah now uses .oompah/tasks exclusively.
# These patterns are kept so local copies of the old .beads/ directory remain
# untracked if present on migrated machines.
.dolt/
*.db
.beads/*.jsonl
.beads/backup/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
*.egg

# Oompah local config
.oompah/*
!.oompah/tasks/
!.oompah/tasks/**

# Per-project console transcripts (oompah-zlz_2-ebwe). Already covered
# by ``.oompah/`` above, but listed explicitly so the path is greppable
# for operators looking up where the console persists state.
.oompah/console/

# Environment variables — never commit secrets
.env

*.log
*.pid

# Historical: beads/Dolt credential key from the old task tracker.
.beads-credential-key
